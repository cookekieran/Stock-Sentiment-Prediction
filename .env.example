# Required only when fetching new Alpha Vantage news locally.
ALPHA_VANTAGE_API_KEY=

# Required only for the Gemini notebooks. GOOGLE_API_KEY is also supported by
# the notebook, but GEMINI_API_KEY is the clearer project convention.
GEMINI_API_KEY=
GEMINI_MODEL_ID=gemini-2.5-flash
GEMINI_BATCH_SIZE=1
GEMINI_SLEEP_SECONDS=4.1

# Required only if notebooks need to read private Hugging Face research snapshots.
HF_TOKEN=

# Required only for the optional local Postgres collector/export scripts.
POSTGRES_PASS=
